{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: NestJS",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run start:dev",
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "name": "Frontend: Angular",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm start",
      "cwd": "${workspaceFolder}/frontend"
    }
  ],
  "compounds": [
    {
      "name": "Backend + Frontend",
      "configurations": [
        "Backend: NestJS",
        "Frontend: Angular"
      ],
      "stopAll": true
    }
  ]
}
